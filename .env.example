# Set this to your domain if running behind a reverse proxy
# Example: https://plex-trakt.yourdomain.com
# Leave as http://localhost:3000 for local development
EXTERNAL_URL=http://localhost:3000

# Unique identifier for your Plex application
# Format: lowercase letters, numbers, and hyphens (e.g., plex-to-trakt-app-abc123)
# You can use any unique string or generate a UUID
PLEX_CLIENT_ID=

# Your Plex server Machine Identifier (optional but recommended)
# Find it via: http://your-plex-server-ip:32400/identity (machineIdentifier field)
# This is used to verify that webhooks are coming from your Plex server
PLEX_SERVER_ID=

# Plex server IP address (for webhook security)
# Use the direct IP of your Plex server (not proxied)
# Example: 192.168.1.100 for local network, or leave empty to allow all IPs
PLEX_SERVER_IP=

# Session Secret (generate a random string)
SESSION_SECRET=

# --- Plex server connection (optional, enables seek correction + full sync) ---
# Base URL of your Plex server. Required for seek correction and full library sync.
# Example: http://192.168.1.100:32400
PLEX_SERVER_URL=

# Plex token used for the /status/sessions poll and full library sync.
# The server owner's token can see all users' sessions. If left empty, the app
# falls back to the logged-in user's own Plex token (works for the owner, may
# not see shared users' sessions).
# How to find yours: https://support.plex.tv/articles/204059436
PLEX_TOKEN=

# --- Full library sync (optional) ---
# Bidirectional sync of watch history between Plex and Trakt on a schedule.
# Watched in Plex but not Trakt -> adds to Trakt history.
# Watched in Trakt but not Plex -> marks as watched in Plex.
# Requires PLEX_SERVER_URL to be set.
# Values: 3h, 6h, 12h, 24h, off (or leave empty to disable)
SYNC_INTERVAL=

# --- Unwatched sync (optional) ---
# When enabled, items unwatched in Plex are also removed from Trakt history,
# and items removed from Trakt history are unmarked in Plex.
# Only takes effect during full sync runs (SYNC_INTERVAL).
# Values: true or false (default: false)
SYNC_UNWATCHED=false

# --- Watch-state quick poller (optional) ---
# Lightweight poller that detects manual "Mark as Watched" / "Mark as Unwatched"
# in Plex and syncs to Trakt within seconds, without waiting for the next full sync.
# Value is the poll interval in seconds (e.g., 60 = every minute).
# Requires PLEX_SERVER_URL. Set to 0 or leave empty to disable.
WATCH_POLL_INTERVAL=

# --- WebSocket listener (optional) ---
# Connects to Plex's WebSocket for instant detection of new media, mark-watched,
# and mark-unwatched events. Supplements webhooks for faster sync.
# Requires PLEX_SERVER_URL and PLEX_TOKEN.
# Values: true or false (default: true)
WS_ENABLED=true

# Direct WebSocket URL for Plex (use when PLEX_SERVER_URL is a reverse proxy).
# Most reverse proxies don't forward WebSocket upgrades. Set this to the direct
# Plex address, e.g., ws://192.168.1.100:32400
# Leave empty to derive from PLEX_SERVER_URL (works when not behind a proxy).
PLEX_WS_URL=

# Maximum WebSocket reconnection delay in milliseconds (default: 60000)
WS_RECONNECT_MAX_MS=60000

# --- Intro/Credit detection (optional) ---
# When enabled, playing a TV episode triggers intro and credit marker detection
# for the NEXT episode in the season, so skip buttons are ready before you get there.
# Requires PLEX_SERVER_URL and PLEX_TOKEN.
# Values: true or false (default: false)
INTRO_DETECTION_ENABLED=false

# --- Activity buffer (optional) ---
# Number of events to keep in the in-memory ring buffer for the SSE activity feed.
# Default: 100
ACTIVITY_BUFFER_SIZE=100
